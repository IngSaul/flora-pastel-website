---
import { business } from "../../content/business";
---

<section class="map-embed">
  <h2>Ubicación</h2>
  <div class="map-embed__frame">
    <iframe
      src={business.mapsEmbedUrl}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Mapa de ubicación de Flora Pastel"></iframe>
  </div>
  <p class="map-embed__address">{business.fullAddress}</p>
  <a
    class="map-embed__directions"
    href={business.mapsDirectionsUrl}
    target="_blank"
    rel="noopener noreferrer"
  >
    Cómo llegar
  </a>
</section>

<style>
  .map-embed {
    margin-bottom: var(--space-6);
  }

  .map-embed__frame {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .map-embed__frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  .map-embed__address {
    margin-top: var(--space-3);
  }

  .map-embed__directions {
    display: inline-block;
    padding: var(--space-1) 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-pink-deep);
    border-bottom: 1px solid currentColor;
    text-decoration: none;
  }
</style>
