---
import { business } from "../../content/business";
---

<section class="business-info">
  <h2>Información de contacto</h2>
  <p class="business-info__address">{business.fullAddress}</p>
  <p class="business-info__phone">Tel: {business.phone}</p>
  <ul class="business-info__hours">
    {
      business.hours.map((entry) => (
        <li>
          <strong>{entry.days}:</strong> {entry.time}
        </li>
      ))
    }
  </ul>
</section>

<style>
  .business-info {
    margin-bottom: var(--space-6);
  }

  .business-info__hours {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
  }

  .business-info__hours li {
    margin-bottom: var(--space-1);
  }
</style>
