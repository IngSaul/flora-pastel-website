---
import { categories } from "../../content/categories";
---

<nav class="category-nav" aria-label="Categorías del catálogo">
  <ul>
    {
      categories.map((category) => (
        <li>
          <a href={`#${category.id}`}>{category.label}</a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .category-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .category-nav a {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    min-height: 24px;
    text-decoration: none;
  }
</style>
