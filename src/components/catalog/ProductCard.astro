---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import type { Category } from "../../content/categories";
import PresentationList from "./PresentationList.astro";
import SobrePedidoNotice from "./SobrePedidoNotice.astro";

interface Props {
  product: CollectionEntry<"products">["data"];
  category: Category;
  priority?: boolean;
}

const { product, category, priority = false } = Astro.props;
const isSobrePedido = category.id === "sobre-pedido";
---

<article class="product-card">
  <Image
    class="product-card__image"
    src={product.images[0]}
    alt={product.name}
    widths={[400, 800, 1200]}
    sizes="100vw"
    format="avif"
    loading={priority ? "eager" : "lazy"}
    fetchpriority={priority ? "high" : "auto"}
  />
  <p class="product-card__category">{category.label}</p>
  <h3 class="product-card__name">{product.name}</h3>
  <p class="product-card__description">{product.description}</p>
  {
    isSobrePedido && category.leadTimeNote && (
      <SobrePedidoNotice leadTimeNote={category.leadTimeNote} />
    )
  }
  <PresentationList
    product={product}
    presentations={product.presentations}
    isSobrePedido={isSobrePedido}
  />
</article>

<style>
  .product-card__image {
    max-width: 100%;
    height: auto;
    display: block;
  }
</style>
