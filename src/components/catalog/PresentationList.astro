---
import type { CollectionEntry } from "astro:content";
import WhatsAppCta from "../shared/WhatsAppCta.astro";

type Presentation =
  CollectionEntry<"products">["data"]["presentations"][number];

interface Props {
  product: CollectionEntry<"products">["data"];
  presentations: Presentation[];
  isSobrePedido?: boolean;
}

const { product, presentations, isSobrePedido = false } = Astro.props;
---

<ul class="presentation-list">
  {
    presentations.map((presentation) => (
      <li class="presentation-list__item">
        <div class="presentation-list__info">
          <span class="presentation-list__label">{presentation.label}</span>
          {presentation.portionDescription && (
            <span class="presentation-list__portion">
              {presentation.portionDescription}
            </span>
          )}
        </div>
        <span class="presentation-list__price">${presentation.priceMXN}</span>
        <WhatsAppCta
          product={product}
          presentation={presentation}
          isSobrePedido={isSobrePedido}
        />
      </li>
    ))
  }
</ul>

<style>
  .presentation-list {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
  }

  .presentation-list__item {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    padding: var(--space-2) 0;
    border-top: 1px solid var(--color-border);
  }

  .presentation-list__info {
    display: flex;
    flex-direction: column;
    margin-right: auto;
  }

  .presentation-list__label {
    font-weight: 600;
    font-size: 13.5px;
    color: var(--color-ink);
  }

  .presentation-list__portion {
    font-size: 12px;
    color: var(--color-ink-muted);
  }

  .presentation-list__price {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 13.5px;
    color: var(--color-coffee);
  }
</style>
