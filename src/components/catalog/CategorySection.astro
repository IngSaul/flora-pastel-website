---
import type { CollectionEntry } from "astro:content";
import type { Category } from "../../content/categories";
import ProductCard from "./ProductCard.astro";
import SobrePedidoNotice from "./SobrePedidoNotice.astro";

interface Props {
  category: Category;
  products: CollectionEntry<"products">[];
  isFirstSection?: boolean;
}

const { category, products, isFirstSection = false } = Astro.props;
---

<section id={category.id} class="category-section">
  <h2>{category.label}</h2>
  {
    category.leadTimeNote && (
      <SobrePedidoNotice leadTimeNote={category.leadTimeNote} />
    )
  }
  <div class="category-section__grid">
    {
      products.map((product, index) => (
        <ProductCard
          product={product.data}
          category={category}
          priority={isFirstSection && index === 0}
        />
      ))
    }
  </div>
</section>
