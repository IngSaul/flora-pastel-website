---
import { business } from "../../content/business";
import { buildGeneralWhatsAppLink } from "../../utils/whatsapp";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/catalogo", label: "Catálogo" },
  { href: "/pasteles-personalizados", label: "Personalizados" },
  { href: "/contacto", label: "Contacto" },
];

const whatsappHref = buildGeneralWhatsAppLink(
  "Hola, me gustaría más información.",
);
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__name">{business.name}</p>

    <nav aria-label="Enlaces del pie de página">
      <ul class="site-footer__links">
        {
          links.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <ul class="site-footer__social">
      <li>
        <a
          href={business.social.facebook}
          target="_blank"
          rel="noopener noreferrer">Facebook</a
        >
      </li>
      <li>
        <a
          href={business.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
        >
          Instagram
        </a>
      </li>
      <li>
        <a
          href={business.social.tiktok}
          target="_blank"
          rel="noopener noreferrer">TikTok</a
        >
      </li>
    </ul>

    <a
      class="site-footer__whatsapp"
      href={whatsappHref}
      target="_blank"
      rel="noopener noreferrer"
    >
      Escríbenos por WhatsApp
    </a>

    <p class="site-footer__copyright">
      {`© ${new Date().getFullYear()} ${business.name}`}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    padding: var(--space-6) 0;
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
  }

  .site-footer__name {
    font-family: var(--font-word);
    font-size: 16px;
    color: var(--color-coffee);
    margin: 0;
  }

  .site-footer__links,
  .site-footer__social {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer__links a,
  .site-footer__social a {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    min-height: 24px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
    text-decoration: none;
  }

  .site-footer__links a:hover,
  .site-footer__social a:hover {
    color: var(--color-pink-deep);
  }

  .site-footer__whatsapp {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    min-height: 24px;
    border-radius: var(--radius-full);
    background: var(--color-whatsapp);
    color: var(--color-black);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.03em;
    text-decoration: none;
  }

  .site-footer__whatsapp:hover {
    background: var(--color-whatsapp-dark);
  }

  .site-footer__copyright {
    color: var(--color-ink-muted);
    font-size: 12px;
    margin: 0;
  }
</style>
