---
import {
  buildWhatsAppLink,
  buildGeneralWhatsAppLink,
} from "../../utils/whatsapp";

interface Props {
  product?: { name: string };
  presentation?: { label: string };
  isSobrePedido?: boolean;
  message?: string;
  label?: string;
  fullWidth?: boolean;
}

const {
  product,
  presentation,
  isSobrePedido = false,
  message,
  label = "Preguntar por WhatsApp",
  fullWidth = true,
} = Astro.props;

const href = message
  ? buildGeneralWhatsAppLink(message)
  : buildWhatsAppLink(product as { name: string }, presentation, isSobrePedido);
---

<a
  class="whatsapp-cta"
  class:list={{ "whatsapp-cta--auto": !fullWidth }}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  {label}
</a>

<style>
  .whatsapp-cta {
    display: inline-flex;
    align-items: center;
    width: 100%;
    justify-content: center;
    margin-top: var(--space-1);
    padding: var(--space-2) var(--space-4);
    min-height: 24px;
    border-radius: var(--radius-full);
    background: var(--color-whatsapp);
    color: var(--color-black);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.03em;
    text-decoration: none;
    text-align: center;
  }

  .whatsapp-cta--auto {
    width: auto;
    margin-top: 0;
    padding: var(--space-3) var(--space-5);
    font-size: 13px;
  }

  .whatsapp-cta:hover {
    background: var(--color-whatsapp-dark);
  }
</style>
