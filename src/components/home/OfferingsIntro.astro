---
const offerings = [
  {
    href: "/catalogo",
    title: "Catálogo completo",
    description:
      "Cheesecakes, gelatinas, panqués, pasteles, postres y productos sobre pedido, con precios por presentación.",
    cta: "Ver catálogo",
  },
  {
    href: "/pasteles-personalizados",
    title: "Pasteles personalizados",
    description:
      "Piezas a medida para bodas, XV años, cumpleaños y eventos corporativos, inspiradas en trabajos anteriores.",
    cta: "Ver personalizados",
  },
];
---

<section class="offerings-intro">
  <h2>¿Qué buscas hoy?</h2>
  <div class="offerings-intro__grid">
    {
      offerings.map((offering) => (
        <article class="offerings-intro__card">
          <h3>{offering.title}</h3>
          <p>{offering.description}</p>
          <a class="offerings-intro__link" href={offering.href}>
            {offering.cta}
          </a>
        </article>
      ))
    }
  </div>
</section>

<style>
  .offerings-intro {
    padding: var(--space-6) 0;
    text-align: center;
  }

  .offerings-intro__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-5);
    text-align: left;
  }

  .offerings-intro__card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    box-shadow: var(--shadow-xs);
  }

  .offerings-intro__link {
    display: inline-block;
    margin-top: var(--space-2);
    padding: var(--space-1) 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-pink-deep);
    border-bottom: 1px solid currentColor;
    text-decoration: none;
  }
</style>
