---
import "../styles/tokens.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Pastelería artesanal en Guadalajara." } =
  Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='16' fill='%23D6478A'/%3E%3C/svg%3E"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fjalla+One&family=Fraunces:ital,wght@0,500;1,500&family=Manrope:wght@400;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Fjalla+One&family=Fraunces:ital,wght@0,500;1,500&family=Manrope:wght@400;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <header class="site-header">
      <nav><a href="/" class="wordmark">Flora Pastel</a></nav>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Flora Pastel</p>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--color-cream);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: inherit;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--color-ink);
    margin: 0 0 0.4em;
    letter-spacing: -0.01em;
  }

  h1 {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1.05;
    font-weight: 400;
  }

  h2 {
    font-size: clamp(1.7rem, 2.6vw, 2.35rem);
    line-height: 1.12;
    font-weight: 400;
  }

  h3 {
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 500;
  }

  p {
    margin: 0 0 1em;
    color: var(--color-ink-muted);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-6) clamp(20px, 5vw, 48px) 0;
  }
</style>

<style>
  .site-header {
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 48px);
  }

  .wordmark {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    margin-left: calc(var(--space-3) * -1);
    min-height: 24px;
    font-family: var(--font-word);
    font-size: 19px;
    letter-spacing: 0.02em;
    color: var(--color-coffee);
    text-decoration: none;
  }

  .site-footer {
    margin-top: var(--space-8);
    padding: var(--space-6) clamp(20px, 5vw, 48px);
    text-align: center;
    color: var(--color-ink-muted);
    font-size: 13px;
  }
</style>
